#!/usr/bin/env bash

VERSION=3.1
echo "--"
echo "-- tmux $VERSION"
echo "--"
sudo apt-get -y install \
    autoconf \
    automake \
    bison \
    build-essential \
    curl \
    git \
    libevent-dev \
    libncurses5-dev \
    pkg-config \
    vim

mkdir -p ~/.local/bin
mkdir -p ~/dev/git && cd ~/dev/git
if [ -d tmux ]
then
    echo "git pull --rebase" && cd tmux && git pull --rebase && make install
else
    echo "git clone https://github.com/tmux/tmux.git" && \
    git clone https://github.com/tmux/tmux.git && git checkout $VERSION && \
    cd tmux && ./autogen.sh && ./configure --prefix=/tmp/tmux-$VERSION && make install
fi

cd /tmp && tar -czf tmux-$VERSION.tar.gz tmux-$VERSION
cd tmux-$VERSION && cp -r * ~/.local
